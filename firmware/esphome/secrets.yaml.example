# Copy this file to secrets.yaml (git-ignored) and fill in real values.
# The CA below is a THROWAWAY example — replace it with your deployment’s
# deploy/mosquitto/certs/mqtt-ca.crt. WiFi + the per-device MQTT password come
# from your network and the eeper Devices → Pair screen.
wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"
eeper_mqtt_password: "paste-the-per-device-password-from-pairing"
