# eeper edge proxy. TLS is terminated here with Caddy's internal (local) CA;
# nothing is exposed to the internet by default (see deploy/README.md).
{
	# No admin API surface, no ACME/public certs — LAN-only, locally signed.
	admin off
	auto_https disable_redirects
	# Bind unprivileged ports inside the container (compose maps host 80/443
	# onto these) so Caddy can run non-root with zero capabilities.
	http_port 8080
	https_port 8443
}

# The site address defaults to localhost (dev/CI). Self-hosters set EEPER_DOMAIN
# to their LAN hostname/IP in .env. `tls internal` issues a cert from the local CA.
{$EEPER_DOMAIN:localhost} {
	tls internal

	# Baseline security headers on every response.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# NOTE: script/style 'unsafe-inline' allows the SvelteKit bootstrap + the
		# inline service-worker registration. Hashed/nonce CSP is deferred — the
		# adapter-static SPA (ssr/prerender off) can't emit SvelteKit CSP hashes,
		# and WebRTC media bypasses CSP by spec, so tightening is all shell risk
		# for zero video benefit. connect-src 'self' covers the same-origin SDP
		# relay; WebRTC media (to go2rtc's published 8555) isn't gated by any fetch
		# directive. Tracked as its own hardening milestone.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'"
		-Server
	}

	# Update-friendly caching — this is what lets a new deploy show up on the next load
	# instead of a stale app shell (the "clear website cache after every update" problem on
	# iOS Safari + installed PWAs). Content-hashed build assets never change, so cache them
	# hard; everything else — the HTML shell, the service worker, the web manifest, icons —
	# must revalidate. ETags (already sent) make each revalidation a cheap 304, not a refetch.
	@immutable path /_app/immutable/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"
	@shell {
		not path /api/*
		not path /_app/immutable/*
	}
	header @shell Cache-Control "no-cache"

	# API traffic to the FastAPI service.
	@api path /api/*
	handle @api {
		reverse_proxy api:8000
	}

	# Everything else is the static PWA.
	handle {
		reverse_proxy web:8080
	}
}

# Redirect all plaintext HTTP to HTTPS. `{host}` omits the port, so we append the
# externally published HTTPS port explicitly — otherwise a non-default
# EEPER_HTTPS_PORT would redirect to a dead :443.
http://{$EEPER_DOMAIN:localhost} {
	redir https://{host}:{$EEPER_HTTPS_PORT:443}{uri} permanent
}
