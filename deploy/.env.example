# eeper environment — TEMPLATE ONLY.
#
# install.sh generates the real ./deploy/.env with random secrets. That file is
# git-ignored and must never be committed. There are NO default credentials.

# Site address Caddy serves and issues a local-CA TLS cert for. Use your LAN
# hostname or IP for a real deployment (e.g. eeper.local or 192.168.1.50).
EEPER_DOMAIN=localhost

# Host interface Caddy binds to. Default 0.0.0.0 (all interfaces). For LAN-only
# exposure set this to your LAN IP. NEVER port-forward these ports to the internet;
# use WireGuard/Tailscale for remote access (see docs/MASTER_PLAN.md §8).
EEPER_BIND_ADDR=0.0.0.0
EEPER_HTTP_PORT=80
EEPER_HTTPS_PORT=443

# Host address a browser reaches go2rtc's WebRTC media port (8555) on. install.sh
# auto-detects the host LAN IP; override here to pin a specific interface. Must be
# a literal IPv4 address, NOT a hostname (Docker binds the port to it). Just
# 127.0.0.1 works only on the host itself — a phone on the LAN needs the host's
# LAN IP. 8555/udp+tcp must be reachable on the LAN for live view; NEVER forward
# it to the internet (use WireGuard/Tailscale for remote access).
EEPER_GO2RTC_CANDIDATE=127.0.0.1

# Secrets — filled with random values by install.sh. Left blank on purpose: the
# stack refuses to start without real values (no defaults anywhere).
POSTGRES_PASSWORD=
EEPER_SECRET_KEY=
